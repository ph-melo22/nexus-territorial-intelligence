# NEXUS — Environment Configuration
# Copy to .env and fill in the values

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Azure AI Foundry ────────────────────────────────────────────────────────
# Azure AI Studio > Project > Settings > Connection String
AZURE_AI_PROJECT_CONNECTION_STRING=<region>.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Portal da Transparência ─────────────────────────────────────────────────
# Free registration: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=your-transparencia-api-key-here

# ── OpenTelemetry (optional) ────────────────────────────────────────────────
# Azure Monitor OTLP endpoint or any OTLP-compatible collector
OTLP_ENDPOINT=https://your-otel-endpoint:4317
OTEL_SERVICE_NAME=nexus-mcp
