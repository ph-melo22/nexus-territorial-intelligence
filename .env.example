# NEXUS — Environment Configuration
# Copy to .env and fill in your values

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Azure AI Foundry (Nova Fábrica) ─────────────────────────────────────────
# Página inicial do projeto > Ponto de extremidade do projeto
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
# Página inicial do projeto > Chave de API
AZURE_AI_API_KEY=your-azure-ai-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── GitHub Models (fallback gratuito — usado se Azure não tiver quota) ───────
# github.com > Settings > Developer settings > Personal access tokens > Generate
GITHUB_TOKEN=your-github-pat-here
GITHUB_MODEL=gpt-4o

# ── Portal da Transparência ─────────────────────────────────────────────────
# Registro gratuito: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=your-transparencia-api-key-here

# ── OpenTelemetry (opcional) ────────────────────────────────────────────────
OTLP_ENDPOINT=
OTEL_SERVICE_NAME=nexus-mcp
